class Solution {
public:
    bool isSubsequence(std::string s, std::string t) {
        int sLen = s.length();
        int tLen = t.length();
        int sPtr = 0;
        int tPtr = 0;
        
        while (sPtr < sLen && tPtr < tLen) {
            if (s[sPtr] == t[tPtr]) {
                sPtr++;
            }
            tPtr++;
        }
        
        return sPtr == sLen;
    }
};
