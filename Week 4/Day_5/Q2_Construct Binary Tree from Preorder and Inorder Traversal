class Solution {
private:
    TreeNode* buildTreeHelper(std::vector<int>& preorder, int& preIdx, int inStart, int inEnd, std::unordered_map<int, int>& inMap) {
        if (inStart > inEnd) {
            return nullptr;
        }

        int rootVal = preorder[preIdx++];
        TreeNode* root = new TreeNode(rootVal);
        int rootInIdx = inMap[rootVal];

        root->left = buildTreeHelper(preorder, preIdx, inStart, rootInIdx - 1, inMap);
        root->right = buildTreeHelper(preorder, preIdx, rootInIdx + 1, inEnd, inMap);

        return root;
    }

public:
    TreeNode* buildTree(std::vector<int>& preorder, std::vector<int>& inorder) {
        std::unordered_map<int, int> inMap;
        for (int i = 0; i < inorder.size(); ++i) {
            inMap[inorder[i]] = i;
        }
        int preIdx = 0;
        return buildTreeHelper(preorder, preIdx, 0, inorder.size() - 1, inMap);
    }
};
