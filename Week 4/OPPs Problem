#include <iostream>

class test {
public:
    virtual int square(int num) = 0;
    virtual ~test() = default;
};

class arithmetic : public test {
public:
    int square(int num) override {
        return num * num;
    }
};

class ToTestInt {
public:
    void testSquare(int num) {
        arithmetic obj;
        std::cout << "Square of " << num << " is: " << obj.square(num) << "\n";
    }
};

class Outer {
public:
    void display() {
        std::cout << "Display from Outer class\n";
    }

    class inner {
    public:
        void display() {
            std::cout << "Display from Inner class\n";
        }
    };
};

class Point {
private:
    int x, y;

public:
    Point() : x(0), y(0) {}
    
    Point(int x, int y) : x(x), y(y) {}

    void setX(int x) {
        this->x = x;
    }

    void setY(int y) {
        this->y = y;
    }

    void setXY(int x, int y) {
        this->x = x;
        this->y = y;
    }

    void printPoint() const {
        std::cout << "Point coordinates: (" << x << ", " << y << ")\n";
    }
};

class box {
protected:
    double length;
    double breadth;

public:
    box(double l, double b) : length(l), breadth(b) {}

    void setLength(double l) {
        length = l;
    }

    void setBreadth(double b) {
        breadth = b;
    }

    double area() const {
        return length * breadth;
    }
};

class box3d : public box {
private:
    double height;

public:
    box3d(double l, double b, double h) : box(l, b), height(h) {}

    void setHeight(double h) {
        height = h;
    }

    double volume() const {
        return area() * height;
    }
};

int main() {
    ToTestInt tester;
    tester.testSquare(5);

    Outer outerObj;
    Outer::inner innerObj;
    outerObj.display();
    innerObj.display();

    Point p1;
    Point p2(10, 20);
    p1.setXY(5, 7);
    p1.printPoint();
    p2.printPoint();

    box3d myBox(4.0, 5.0, 6.0);
    std::cout << "Box Area: " << myBox.area() << "\n";
    std::cout << "Box Volume: " << myBox.volume() << "\n";

    return 0;
}
