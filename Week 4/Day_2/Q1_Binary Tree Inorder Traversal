class Solution {
private:
    void inorder(TreeNode* root, std::vector<int>& nodes) {
        if (root == nullptr) {
            return;
        }
        inorder(root->left, nodes);
        nodes.push_back(root->val);
        inorder(root->right, nodes);
    }

public:
    std::vector<int> inorderTraversal(TreeNode* root) {
        std::vector<int> result;
        inorder(root, result);
        return result;
    }
};

